SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-secret-key
PORT=3001
CRON_SECRET=change-me-for-daily-cron
ADMIN_ALERT_EMAIL=admin@example.com
# Postgres URI from Supabase Dashboard → Database → Connection string (for scripts/apply-migrations.mjs)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Local dev
FRONTEND_URL=http://localhost:5173

# Production (Render): exact Vercel site origin, no trailing slash
# FRONTEND_URL=https://your-app.vercel.app
# Multiple preview URLs: comma-separated, no spaces after commas
# FRONTEND_URL=https://your-app.vercel.app,https://your-app-git-main-user.vercel.app
